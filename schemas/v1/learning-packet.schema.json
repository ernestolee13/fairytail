{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fairytail.local/schemas/v1/learning-packet.schema.json",
  "title": "Fairytail closed learning packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "producer",
    "build_packet_hash",
    "protected_render_hash",
    "protected_render",
    "verified_task_result"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "packet_id": {
      "type": "string",
      "pattern": "^fairytail\\.learning\\.v1\\.[a-f0-9]{64}$"
    },
    "producer": { "$ref": "#/$defs/producer" },
    "build_packet_hash": { "$ref": "#/$defs/hash" },
    "protected_render_hash": { "$ref": "#/$defs/hash" },
    "protected_render": { "$ref": "#/$defs/protectedRender" },
    "verified_task_result": { "$ref": "#/$defs/verifiedTaskResult" }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "model_id",
        "packet_validated",
        "parent_model_changed"
      ],
      "properties": {
        "role": { "const": "primary_reasoning_model" },
        "model_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120,
          "pattern": "^(?=.*[0-9])[A-Za-z0-9][A-Za-z0-9._:/-]{2,119}$",
          "not": {
            "pattern": "(^|[._:/-])(fast|flash|haiku|latest|lite|mini|nano|small|spark)($|[._:/-])"
          }
        },
        "packet_validated": { "const": true },
        "parent_model_changed": { "const": false }
      }
    },
    "protectedRender": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locale", "content"],
      "properties": {
        "locale": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requested_locale",
            "resolved_locale",
            "source_locale",
            "fallback_reason",
            "catalog_hash"
          ],
          "properties": {
            "requested_locale": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "string",
                  "maxLength": 35,
                  "pattern": "^[a-z]{2,3}(?:-[a-z0-9]{2,8})*$"
                }
              ]
            },
            "resolved_locale": { "enum": ["en", "ko"] },
            "source_locale": { "const": "en" },
            "fallback_reason": {
              "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/identifier" }]
            },
            "catalog_hash": {
              "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/hash" }]
            }
          }
        },
        "content": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "canonical_definition",
            "current_encounter",
            "analogy_or_neutral_fallback",
            "analogy_breakpoint",
            "target_side_effect_risk_rollback",
            "one_next_action_and_evidence",
            "diagnostic_or_teachback",
            "protocol_fact_and_fairytail_policy_labels"
          ],
          "properties": {
            "canonical_definition": { "type": "object" },
            "current_encounter": { "type": "object" },
            "analogy_or_neutral_fallback": { "type": "object" },
            "analogy_breakpoint": { "type": "object" },
            "target_side_effect_risk_rollback": { "type": "object" },
            "one_next_action_and_evidence": { "type": "object" },
            "diagnostic_or_teachback": { "type": "object" },
            "protocol_fact_and_fairytail_policy_labels": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      }
    },
    "verifiedTaskResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_id", "status", "outcome", "summary", "verification"],
      "properties": {
        "result_id": { "$ref": "#/$defs/identifier" },
        "status": { "const": "verified" },
        "outcome": { "enum": ["changed", "no_change"] },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240,
          "pattern": "^[^\\r\\n`{}]*$"
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["check_id", "status", "evidence_id"],
          "properties": {
            "check_id": { "$ref": "#/$defs/identifier" },
            "status": { "const": "passed" },
            "evidence_id": { "$ref": "#/$defs/identifier" }
          }
        }
      }
    }
  }
}
