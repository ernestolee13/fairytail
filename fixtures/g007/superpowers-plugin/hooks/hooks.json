{
  "description": "Inert Superpowers-shaped coexistence fixture",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/session-start.mjs",
              "--data-dir",
              "${CLAUDE_PLUGIN_DATA}"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
