{
  "description": "Fairytail privacy-preserving lifecycle cues and deterministic PreToolUse safety guard",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/fairytail-hook.mjs",
              "--expected-event",
              "SessionStart",
              "--data-dir",
              "${CLAUDE_PLUGIN_DATA}"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|Write|Edit|MultiEdit|NotebookEdit|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/fairytail-hook.mjs",
              "--expected-event",
              "PreToolUse",
              "--data-dir",
              "${CLAUDE_PLUGIN_DATA}"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/fairytail-hook.mjs",
              "--expected-event",
              "PostToolUse",
              "--data-dir",
              "${CLAUDE_PLUGIN_DATA}"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "^(Bash|Write|Edit|MultiEdit|NotebookEdit|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/fairytail-hook.mjs",
              "--expected-event",
              "PostToolUseFailure",
              "--data-dir",
              "${CLAUDE_PLUGIN_DATA}"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
