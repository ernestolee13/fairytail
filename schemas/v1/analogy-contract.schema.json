{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fairytail.local/schemas/v1/analogy-contract.schema.json",
  "title": "Fairytail analogy relation contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "concept_id",
    "canonical_fact_hash",
    "role_ids",
    "required_relations"
  ],
  "properties": {
    "contract_version": { "const": 1 },
    "concept_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "canonical_fact_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "role_ids": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 40 }
    },
    "required_relations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relation_id", "from_role", "relation", "to_role"],
        "properties": {
          "relation_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "from_role": { "type": "string", "minLength": 1 },
          "relation": { "type": "string", "minLength": 1 },
          "to_role": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
