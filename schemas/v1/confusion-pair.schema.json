{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fairytail.local/schemas/v1/confusion-pair.schema.json",
  "title": "Fairytail confusion pair v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pair_id",
    "concepts",
    "fixed_distinction",
    "diagnostic_question",
    "source_concept_ids"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "pair_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "concepts": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "fixed_distinction": { "type": "string", "minLength": 1 },
    "diagnostic_question": { "type": "string", "minLength": 1 },
    "source_concept_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "uniqueItems": true
    }
  }
}
