{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fairytail.local/schemas/v1/analogy-cache.schema.json",
  "title": "Fairytail analogy cache v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["cache_version", "entries", "rejections"],
  "properties": {
    "cache_version": { "const": 1 },
    "entries": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cache_key",
          "scenario_id",
          "mapping_id",
          "mapping_version",
          "mapping_hash",
          "content_version",
          "canonical_fact_set_hash",
          "contract_version",
          "catalog_version",
          "renderer_version",
          "locale",
          "choice"
        ],
        "properties": {
          "cache_key": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "scenario_id": { "type": "string", "pattern": "^S[0-9]{2}$" },
          "mapping_id": {
            "type": "string",
            "pattern": "^P[1-9][0-9]*-S[0-9]{2}-A[1-9][0-9]*$"
          },
          "mapping_version": { "type": "integer", "minimum": 1 },
          "mapping_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "content_version": {
            "type": "string",
            "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[0-9]+$"
          },
          "canonical_fact_set_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "contract_version": { "type": "integer", "minimum": 1 },
          "catalog_version": {
            "type": "string",
            "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[0-9]+$"
          },
          "renderer_version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "locale": { "enum": ["en", "ko"] },
          "choice": { "enum": ["preferred", "different", "unfamiliar"] }
        }
      }
    },
    "rejections": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mapping_id", "mapping_version", "reason_code"],
        "properties": {
          "mapping_id": {
            "type": "string",
            "pattern": "^P[1-9][0-9]*-S[0-9]{2}-A[1-9][0-9]*$"
          },
          "mapping_version": { "type": "integer", "minimum": 1 },
          "reason_code": { "enum": ["unfamiliar", "rejected"] }
        }
      }
    }
  }
}
