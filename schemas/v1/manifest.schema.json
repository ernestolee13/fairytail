{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fairytail.local/schemas/v1/manifest.schema.json",
  "title": "Fairytail content manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "content_version",
    "verified_at",
    "canonical_hash_algorithm",
    "counts",
    "canonical_hashes",
    "scenario_fact_hashes",
    "personalization_ready"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "content_version": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[0-9]+$"
    },
    "verified_at": { "type": "string", "format": "date" },
    "canonical_hash_algorithm": { "const": "sha256-stable-json-v1" },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "concepts",
        "confusion_pairs",
        "profiles",
        "scenarios",
        "analogy_candidates",
        "golden_cases"
      ],
      "properties": {
        "concepts": { "const": 12 },
        "confusion_pairs": { "const": 12 },
        "profiles": { "const": 3 },
        "scenarios": { "const": 10 },
        "analogy_candidates": { "const": 30 },
        "golden_cases": { "const": 30 }
      }
    },
    "canonical_hashes": {
      "type": "object",
      "minProperties": 12,
      "maxProperties": 12,
      "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
    },
    "scenario_fact_hashes": {
      "type": "object",
      "minProperties": 10,
      "maxProperties": 10,
      "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
    },
    "personalization_ready": { "const": false }
  }
}
